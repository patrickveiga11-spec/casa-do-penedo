DATABASE_URL="postgresql://casa:casa@localhost:5432/casa_do_penedo?schema=public"
API_PORT=3001
VITE_API_URL=http://localhost:3001

# Brevo — opção mais simples (recomendada)
# Settings → SMTP & API → API Keys → Create API key
BREVO_API_KEY=

# Brevo SMTP (alternativa)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Casa do Penedo <casa_do_penedo@casadopenedo.pt>"
OWNER_EMAIL=casa_do_penedo@casadopenedo.pt
BREVO_SENDER_EMAIL=casa_do_penedo@casadopenedo.pt

# Password da área de gestão (/gestao) — escolhe uma password forte
ADMIN_PASSWORD=

# Produção (Render): usa PORT automático; não precisas de API_PORT
# Produção (Vercel): VITE_API_URL=https://a-tua-api.onrender.com
