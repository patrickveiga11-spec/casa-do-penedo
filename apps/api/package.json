    "db:generate": "prisma generate",
    "test:email": "tsx scripts/test-email.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@prisma/client": "^6.3.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "nodemailer": "^8.0.10",
    "prisma": "^6.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "embedded-postgres": "^18.3.0-beta.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
